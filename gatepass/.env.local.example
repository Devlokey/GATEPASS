# ============================================================
# Gatepass — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Transactional Email) ──────────────────────────────
# Get from: resend.com → API Keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key

# ── Razorpay (Payments) ───────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
# Only required for events with paid tickets
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret

# ── App ───────────────────────────────────────────────────────
# Used in emails and QR deep links
# For local development: http://localhost:3000
# For production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
